DB_HOST=localhost
DB_PORT=5432
DB_NAME=invest
DB_USER=postgres
DB_PASSWORD=your_password_here

# E.Sun intraday real-time quotes (esun_marketdata SDK)
# Absolute path to the .ini file with [Core]/[Cert]/[Api]/[User] sections.
ESUN_CONFIG_INI=

# SinoPac (永豐) Shioaji — used by pre_market_update.py to fetch the
# reference price + price limits before each trading day. Market-data only,
# no CA cert needed.
SINOPAC_API_KEY=
SINOPAC_SECRET_KEY=